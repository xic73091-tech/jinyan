// 你好.cy —— 诚言语言的第一个程序
// 运行方式: chengyan 你好.cy

函数 主函数() {
    让 消息 = "你好，世界！"
    打印(消息)

    让 数字 = 42
    如果 数字 == 42 {
        打印("答案是" + 文本化(数字))
    }

    // 循环示例
    让 总和 = 0
    让 计数 = 1
    当 计数 <= 10 {
        总和 = 总和 + 计数
        计数 = 计数 + 1
    }
    打印("1到10的总和是" + 文本化(总和))

    // 数组示例
    让 颜色 = ["红", "橙", "黄", "绿", "蓝"]
    让 索引 = 0
    当 索引 < 长度(颜色) {
        打印("颜色" + 文本化(索引) + ": " + 颜色[索引])
        索引 = 索引 + 1
    }

    // 函数作为值
    让 加法 = 箭头(甲, 乙) {
        返回 甲 + 乙
    }
    打印("3 + 5 = " + 文本化(加法(3, 5)))
}

主函数()
